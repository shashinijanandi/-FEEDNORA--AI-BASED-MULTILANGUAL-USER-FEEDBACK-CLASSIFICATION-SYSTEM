# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="AI Feedback Analytics Platform"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db:5432/feedback_analytics

# ─── JWT (CHANGE THESE IN PRODUCTION!) ────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-must-be-32-chars-minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── AI Models ────────────────────────────────────────────────────────────────
MODEL_PATH=ai_models/sentiment_model.pkl
VECTORIZER_PATH=ai_models/vectorizer.pkl

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
