# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=FeedbackAI Platform
APP_VERSION=3.0.0
DEBUG=false

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-char-minimum-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db:5432/feedbackai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=feedbackai

# ─── AI Models ────────────────────────────────────────────────────────────────
SENTIMENT_MODEL_PATH=ai_models/sentiment_model.pkl
VECTORIZER_PATH=ai_models/vectorizer.pkl

# ─── Topic modeling artifacts (Sync Trained Model / static PNGs) ───────────────
# Docker Compose: set in docker-compose.yml to /artifacts/... (volume ../../artifacts).
# Local uvicorn (cwd=backend): defaults ../artifacts/... or use absolute Windows paths.
# TOPIC_OUTPUT_CSV_PATH=../artifacts/topics.csv
# TOPIC_DATASET_CSV_PATH=../artifacts/labeled_feedback.csv
# TOPIC_ARTIFACTS_DIR=../artifacts
TOPIC_MODEL_VERSION=v1

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost
